# Corpus ingestion (scripts/ingest.py — lands in phase 1)
# Seed list of public URLs to index — content itself is never committed (data/ is gitignored)
CORPUS_SEED_FILE=scripts/seed_urls_wavestone.txt
DATA_DIR=data

# Search mode: bm25 | hybrid (hybrid needs `pip install .[hybrid]`)
SEARCH_MODE=bm25
# Embedding model for hybrid mode (fastembed / ONNX, downloaded on first run)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Bearer token required by the MCP server in HTTP mode (phase 3)
MCP_AUTH_TOKEN=changeme

# MCP HTTP transport port (phase 3)
MCP_PORT=8020
